cd lsseq/tests/testdir/symdirB

find -L . -name '*.100.exr' | sort > files.list

ls -r -t -l -H --time-style="+%Y-%m-%d %H:%M:%S" `cat files.list` > ls.fileDeRef.r.out

ls -r -t -l -F --time-style="+%Y-%m-%d %H:%M:%S" `cat files.list` > ls.noFileDeRef.r.out

lsseq -Z -R -G -P -r --dereference-symlink-to-dir > lsseq.noFileDeRef.r.out

lsseq -Z -R -G -P -r --dereference > lsseq.fileDeRef.r.out

...then diff the above files between each other.
